{
  "name": "@timdaik/slidev-theme-nutmeg",
  "private": false,
  "version": "0.2.1",
  "description": "NUTMEG Slidev theme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hengin-eer/nutmeg-slidev.git",
    "directory": "packages/slidev-theme"
  },
  "scripts": {
    "dev": "slidev catalog/slides.md",
    "build": "node scripts/build-catalog.mjs",
    "build:pages": "node scripts/build-catalog.mjs --pages",
    "catalog:serve": "node scripts/serve-catalog.mjs",
    "export": "slidev export catalog/slides.md",
    "check:package": "npm pack --dry-run"
  },
  "keywords": [
    "slidev-theme",
    "slidev",
    "nutmeg",
    "nutfes"
  ],
  "files": [
    "assets",
    "components",
    "layouts",
    "styles",
    "global-top.vue",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.14.0",
    "slidev": ">=52.16.0 <53"
  },
  "slidev": {
    "colorSchema": "light",
    "defaults": {
      "aspectRatio": "16/9",
      "fonts": {
        "provider": "none",
        "sans": "Noto Sans JP"
      }
    }
  },
  "dependencies": {
    "@fontsource/noto-sans-jp": "^5.2.6"
  },
  "peerDependencies": {
    "@slidev/cli": "^52.16.0"
  },
  "devDependencies": {
    "@slidev/cli": "^52.16.0"
  }
}
